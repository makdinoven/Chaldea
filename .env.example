# =============================================================================
# Chaldea — Environment Variables
# =============================================================================
# Copy this file to .env and fill in real values before deploying.
# NEVER commit .env with real secrets to the repository.
# =============================================================================

# --- MySQL ---
MYSQL_ROOT_PASSWORD=change-me-root-password
MYSQL_DATABASE=mydatabase
MYSQL_USER=myuser
MYSQL_PASSWORD=change-me-db-password

# --- RabbitMQ ---
RABBITMQ_DEFAULT_USER=change-me-rmq-user
RABBITMQ_DEFAULT_PASS=change-me-rmq-password

# --- JWT ---
JWT_SECRET_KEY=change-me-jwt-secret-at-least-32-chars

# --- S3 / Backblaze B2 (photo-service) ---
AWS_ACCESS_KEY_ID=your-access-key-id
AWS_SECRET_ACCESS_KEY=your-secret-access-key
S3_ENDPOINT_URL=https://s3.eu-central-003.backblazeb2.com
S3_BUCKET_NAME=your-bucket-name
S3_REGION=eu-central-003

# --- CORS ---
# Comma-separated list of allowed origins. Use * for development.
# Production example: https://fallofgods.top
CORS_ORIGINS=*

# --- Domain (used in nginx) ---
DOMAIN=fallofgods.top
